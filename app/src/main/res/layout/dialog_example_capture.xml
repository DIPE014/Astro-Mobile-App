<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface_variant"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/padding_large">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/example_capture_title"
            android:textAppearance="@style/TextAppearance.AstroApp.TitleLarge"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="@dimen/margin_medium" />

        <!-- Full-size example image -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:contentDescription="@string/example_capture_cd"
            android:scaleType="fitCenter"
            android:src="@drawable/example_capture" />

        <!-- Caption -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="@dimen/margin_medium"
            android:text="@string/example_capture_caption"
            android:textAppearance="@style/TextAppearance.AstroApp.BodyMedium"
            android:textColor="@color/text_secondary" />

        <!-- Close button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGotIt"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/example_capture_close"
            android:textAllCaps="false"
            android:layout_marginTop="@dimen/margin_medium" />

    </LinearLayout>
</ScrollView>
